pipeline {
    agent any

    tools {
        maven 'mymaven'
    }

    environment {
        TOMCAT_HOME = '/opt/tomcat'
        WAR_NAME = 'web.war'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/ruship13/jenkins.git'
            }
        }

        stage('Compile Code') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('Test Code') {
            steps {
                sh 'mvn test'
            }
        }

        stage('Build WAR') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Stop Tomcat') {
            steps {
                sh '''
                sudo $TOMCAT_HOME/bin/shutdown.sh || true
                sleep 10
                '''
            }
        }

        stage('Delete Old WAR') {
            steps {
                sh '''
                sudo rm -rf $TOMCAT_HOME/webapps/web*
                '''
            }
        }

        stage('Deploy New WAR') {
            steps {
                sh '''
                sudo cp target/*.war $TOMCAT_HOME/webapps/$WAR_NAME
                '''
            }
        }

        stage('Start Tomcat') {
            steps {
                sh '''
                sudo $TOMCAT_HOME/bin/startup.sh
                sleep 15
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                curl -I http://localhost:8088
                '''
            }
        }
    }
}