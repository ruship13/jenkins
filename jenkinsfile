pipeline {
    agent any

    tools {
        maven 'mymaven'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/ruship13/jenkins.git'
            }
        }

        stage('Build & Package') {
            steps {
                sh 'mvn clean install'
            }
        }
        stage('Deployment') {
    deploy adapters: [
        tomcat9(
            credentialsId: 'TomcatCreds',
            path: '',
            url: 'http://localhost:8088/'
        )
    ],
    contextPath: null,
    war: 'target/*.war'
}
        
    }

    post {
        success {
            echo 'Deployment Successful!'
        }
        failure {
            echo 'Build or Deployment Failed!'
        }
    }
}