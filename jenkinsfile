pipeline {
    agent any

    tools {
        maven 'mymaven'
    }

    environment {
        TOMCAT_HOME = "C:\\Program Files\\Apache Software Foundation\\Tomcat 9.0_Tomcat9.0"
    WAR_FILE = "demo-0.0.1-SNAPSHOT.war"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/ruship13/jenkins.git'
            }
        }

        stage('Build WAR') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Stop Tomcat') {
            steps {
                bat '''
                "%TOMCAT_HOME%\\bin\\shutdown.bat"
                '''
            }
        }

        stage('Delete Old Deployment') {
            steps {
                bat '''
                rmdir /s /q "%TOMCAT_HOME%\\webapps\\demo-0.0.1-SNAPSHOT" 2>nul
                del /f /q "%TOMCAT_HOME%\\webapps\\%WAR_FILE%" 2>nul
                '''
            }
        }

        stage('Deploy New WAR') {
            steps {
                bat '''
                copy target\\%WAR_FILE% "%TOMCAT_HOME%\\webapps\\"
                '''
            }
        }

        stage('Start Tomcat') {
            steps {
                bat '''
                "%TOMCAT_HOME%\\bin\\startup.bat"
                '''
            }
        }
    }
}