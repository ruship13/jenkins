pipeline {
    agent any

    tools {
        maven 'mymaven'
    }

    environment {
        TOMCAT_PATH = 'C:\\Program Files\\Apache Software Foundation\\Tomcat 9.0_Tomcat9.0\\webapps'
        WAR_NAME = 'demo-0.0.1-SNAPSHOT.war'
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/ruship13/jenkins.git'
            }
        }

        stage('Clean Project') {
            steps {
                bat 'mvn clean'
            }
        }

        stage('Compile Code') {
            steps {
                bat 'mvn compile'
            }
        }

        stage('Test Code') {
            steps {
                bat 'mvn test'
            }
        }

        stage('Package Code') {
            steps {
                bat 'mvn package'
            }
        }

        stage('Stop Tomcat') {
            steps {
                bat '''
                net stop Tomcat9
                '''
            }
        }

        stage('Delete Old WAR') {
            steps {
                bat """
                if exist "%TOMCAT_PATH%\\demo-0.0.1-SNAPSHOT" rmdir /s /q "%TOMCAT_PATH%\\demo-0.0.1-SNAPSHOT"

                if exist "%TOMCAT_PATH%\\%WAR_NAME%" del /f /q "%TOMCAT_PATH%\\%WAR_NAME%"
                """
            }
        }

        stage('Deploy New WAR') {
            steps {
                bat """
                copy target\\%WAR_NAME% "%TOMCAT_PATH%"
                """
            }
        }

        stage('Start Tomcat') {
            steps {
                bat '''
                net start Tomcat9
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                bat '''
                timeout /t 15
                curl http://localhost:8088/demo-0.0.1-SNAPSHOT
                '''
            }
        }
    }

    post {
        success {
            echo 'Application deployed successfully'
        }

        failure {
            echo 'Deployment failed'
        }
    }
}